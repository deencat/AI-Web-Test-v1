# ============================================
# AI Web Test Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#   copy env.example .env   (Windows)
#   cp env.example .env     (Mac/Linux)
# DO NOT commit .env to git — it contains secrets.
# ============================================

# ============================================
# Database
# ============================================
# Local development (SQLite — no Docker required)
DATABASE_URL=sqlite:///./aiwebtest.db

# Production (PostgreSQL via Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiwebtest

# ============================================
# Security & Authentication
# ============================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Fernet AES-128 key for HTTP credential + email OTP storage
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=your-credential-encryption-key

# ============================================
# CORS
# ============================================
# JSON list of origins allowed to call the API
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# ============================================
# Model Provider
# ============================================
# Options: openrouter | google | cerebras | azure | local_vllm
MODEL_PROVIDER=openrouter

# Legacy flags (still supported for backward compatibility)
# USE_GOOGLE_DIRECT=false
# USE_CEREBRAS=false

# ============================================
# Azure OpenAI  (MODEL_PROVIDER=azure)
# ============================================
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/openai/v1
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_MODEL=ChatGPT-UAT

# Optional: separate deployment for gpt-5.2 (east-us2 resource)
# AZURE_OPENAI_GPT52_API_KEY=your-gpt52-key
# AZURE_OPENAI_GPT52_ENDPOINT=https://your-gpt52-resource.cognitiveservices.azure.com
# AZURE_OPENAI_GPT52_API_VERSION=2024-12-01-preview

# ============================================
# OpenRouter  (MODEL_PROVIDER=openrouter)
# ============================================
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct
# Free alternatives: meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-chat
# Paid (better quality): anthropic/claude-3.5-sonnet, anthropic/claude-3-haiku

# Stagehand uses OpenRouter via OpenAI-compatible base
OPENAI_API_KEY=sk-or-v1-your-api-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# ============================================
# Google AI Studio  (MODEL_PROVIDER=google)
# ============================================
# Get key: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-1.5-flash

# ============================================
# Cerebras  (MODEL_PROVIDER=cerebras)
# ============================================
# Get key: https://cloud.cerebras.ai/
# CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=llama3.1-8b

# ============================================
# Browser
# ============================================
HEADLESS_BROWSER=false
# BROWSER_HEADLESS=true   # alias for HEADLESS_BROWSER
# BROWSER_SLOWMO=0

# Connect to a manually-started Chrome instance (avoids automation flags causing loops):
#   1. Run:  backend\scripts\start_browser_for_observation.bat
#   2. Uncomment the line below and restart the server.
# BROWSER_CDP_URL=http://127.0.0.1:9222

# ============================================
# API
# ============================================
API_V1_STR=/api/v1
API_V2_STR=/api/v2
PROJECT_NAME=AI Web Test

# ============================================
# Execution queue
# ============================================
MAX_CONCURRENT_EXECUTIONS=5
QUEUE_CHECK_INTERVAL=2
EXECUTION_TIMEOUT=300

# ============================================
# Runtime flags
# ============================================
# Set false to skip browser execution in CI environments
ENABLE_ANALYSIS_REALTIME_EXECUTION=true

# Write daily log files to backend/logs/
ENABLE_SERVER_FILE_LOGGING=false

# After ObservationAgent: write flow recording JSON under artifacts/flow_recordings/
FLOW_RECORDINGS_ENABLED=true
# FLOW_RECORDINGS_DIR=

# ============================================
# Feature 3: App State Graph (ASG)
# ============================================
# Master switch for ASG-primary test generation in generate-tests workflow
ASG_ENABLED=false
# Build graphs in parallel without replacing legacy output (default on)
ASG_SHADOW_MODE=true
# Minimum confidence to use ASG output instead of legacy evolution path
ASG_CONFIDENCE_MIN=0.75
# Comma-separated project IDs for progressive rollout (empty = all projects)
# ASG_PROJECT_ALLOWLIST=

# ============================================
# Email OTP (IMAP polling)
# ============================================
EMAIL_OTP_POLL_TIMEOUT=60
EMAIL_OTP_POLL_INTERVAL=3

# ============================================
# ReqIQ Integration  (server-to-server only)
# ============================================
# NEVER expose these to the browser / frontend.
# Create a ReqIQ service account with role ANALYST or LIBRARIAN.
# See docs/AI-Web-Test-Developer-Handoff.md §4 for full setup.

REQIQ_URL=http://localhost:3001
REQIQ_SERVICE_EMAIL=aiwebtest@reqiq.local
REQIQ_SERVICE_PASSWORD=your-reqiq-service-password

# Optional: pre-issued JWT instead of email+password (refresh on 401, TTL ~8h)
# REQIQ_SERVICE_TOKEN=eyJhbGci...

# Optional: informational only (JWT carries tenant context)
# REQIQ_TENANT_ID=your-reqiq-tenant-cuid

# Optional: pin a default project for KB context injection
# REQIQ_PROJECT_ID_VOUCHER_PLAN=your-reqiq-project-cuid

# Optional: ReqIQ web UI URL for the "Open ReqIQ Advanced" link
# REQIQ_WEB_URL=http://localhost:8080

# ============================================
# MCP Server  (Hermes Agent integration)
# ============================================
# Standalone MCP server on port AWT_MCP_PORT that Hermes profiles use
# instead of calling AI Web Test REST endpoints directly.
#
# Start alongside the main server:
#   python mcp_server.py
#
# Hermes profile config  (~/.hermes/profiles/qa-test-gen/mcp_servers.yaml):
#   servers:
#     - name: ai-web-test
#       transport: http
#       url: http://<THIS_HOST_IP>:8001/mcp
#       headers:
#         Authorization: "Bearer ${AWT_MCP_SECRET}"

AWT_MCP_SECRET=change-this-to-a-strong-random-secret
AWT_MCP_PORT=8001
AWT_BASE_URL=http://localhost:8000/api/v1
AWT_SERVICE_USERNAME=admin
AWT_SERVICE_PASSWORD=your-admin-password

# Hermes Telegram trigger (H2 — "Generate via Hermes" button in UI)
# Same bot token as TELEGRAM_BOT_TOKEN in ~/.hermes/.env on Node 1.
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# QA_MANAGER_TELEGRAM_CHAT_ID=your-chat-id

# ============================================
# Local vLLM  (MODEL_PROVIDER=local_vllm)
# ============================================
# Per-model endpoint overrides (defaults shown below).
# LOCAL_VLLM_GPT_OSS_20B_ENDPOINT=http://192.168.206.190:8000/openai--gpt-oss-20b/v1
# LOCAL_VLLM_QWEN3_35B_ENDPOINT=http://192.168.206.190:8000/redhatai--qwen3.6-35b-a3b-nvfp4/v1
# LOCAL_VLLM_DEEPSEEK_ENDPOINT=http://192.168.206.164:1235/v1
# LOCAL_VLLM_API_KEY=local

# Qwen3.6-35B-A3B-MLX-8bit (8-bit MLX quantisation)
# LOCAL_VLLM_MLX_ENDPOINT=http://192.168.206.164:1235/v1
# LOCAL_VLLM_MLX_API_KEY=1235

# ============================================
# Three HK Preprod API OTP (non-browser)
# ============================================
# QA diagnostic endpoint — requires corp/VPN network access
THREE_PREPROD_OTP_API_URL=your-preprod-otp-url
PREPROD_OTP_POLL_TIMEOUT=60
PREPROD_OTP_POLL_INTERVAL=3
PREPROD_OTP_UAT_ONLY=true
PREPROD_OTP_SSL_VERIFY=false
# PREPROD_OTP_SSL_CA_BUNDLE=/path/to/corp-ca.pem

# ============================================
# LLM Response & Timing Log
# ============================================
LLM_LOG_DIR=logs/llm
LLM_LOG_MAX_FILES=200
LLM_LOG_FULL_PROMPT=false
