# Hermes dev Ubuntu (mini PC) — copy to ~/.hermes/.env
# HF-7 · See Hermes_Environment_Migration_Guide.md

# --- AI Web Test connectivity (dev Windows / dev server) ---
AWT_MCP_URL=http://192.168.1.100:8001
AWT_AGENT_EVENTS_URL=http://192.168.1.100:8000/api/v1/agent/hermes/events

# Must match backend/.env on AWT dev
AWT_MCP_SECRET=change-me-mcp-secret
HERMES_BRIDGE_SECRET=change-me-bridge-secret

# Bridge service (this Ubuntu host)
HERMES_BRIDGE_PORT=8790
HERMES_BRIDGE_DEMO_MODE=0
# Optional: real orchestrator when Hermes profiles ready (set DEMO_MODE=0)
HERMES_ORCHESTRATOR_CMD=qa-orchestrator
# ReqIQ (qa-journey-planner — via AWT MCP proxy; optional direct curl fallback)
REQIQ_API_URL=http://192.168.1.100:3001
REQIQ_API_KEY=refresh-every-8h-see-v4-guide
REQIQ_PROJECT_ID=clxxxxxxxxxxxxxxxxxx

# Test credentials (qa-test-gen crawl — never commit real values)
TEST_LOGIN_USERNAME=
TEST_LOGIN_PASSWORD=
HTTP_AUTH_USERNAME=
HTTP_AUTH_PASSWORD=

# LLM (OpenRouter / Ollama — per profile config.yaml)
OPENROUTER_API_KEY=change-me
