# Add to AWT backend/.env when Hermes Ubuntu is deployed
# Update host when moving dev mini PC → prod PC

# Hermes dev (mini PC):
# HERMES_BRIDGE_URL=http://192.168.1.50:8790
# HERMES_BRIDGE_SECRET=change-me-bridge-secret

# Hermes prod (bigger PC):
# HERMES_BRIDGE_URL=http://10.0.0.20:8790
# HERMES_BRIDGE_SECRET=prod-bridge-secret-rotated
