# Hermes prod Ubuntu — copy to ~/.hermes/.env
# HF-7 · ROTATE all secrets — do not copy dev values

AWT_MCP_URL=https://awt-prod.example.com:8001
AWT_AGENT_EVENTS_URL=https://awt-prod.example.com/api/v1/agent/hermes/events

AWT_MCP_SECRET=prod-mcp-secret-rotated
HERMES_BRIDGE_SECRET=prod-bridge-secret-rotated

HERMES_BRIDGE_PORT=8790
HERMES_BRIDGE_DEMO_MODE=0
HERMES_ORCHESTRATOR_CMD=qa-orchestrator

REQIQ_API_URL=https://reqiq-prod.example.com:3001
REQIQ_API_KEY=prod-reqiq-jwt

OPENROUTER_API_KEY=prod-openrouter-key
